    {
      "id": "explicit_question_with_chapter_override",
      "category": "explicit_task",
      "history": [
        {"role": "user", "content": "发了一张有三道题的图片"},
        {"role": "assistant", "content": "我识别到三道题，请选择要查的题号。"}
      ],
      "context": {"phase": "WAIT_QUESTION_CHOICE", "active_namespace": "question", "question_count": 3, "candidate_count": 0, "has_active_image": true},
      "input": {"event_type": "text", "text": "第二题按力法搜"},
      "expected_decision": {"action": "select_question", "question_index": 2, "chapter_override": "4力法"},
      "expected_authorization": {"outcome": "allow", "code": "select_question", "state_effect": "update_task", "tool_effect": "fixed_search_pipeline"}
    },
    {
